{
  "expo": {
    "name": "Ekolglass Montaj Takip",
    "slug": "ekolglassmontajtakip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ekolglassmontajtakip",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f6f9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ekolglassmontajtakip.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Montaj fotoğrafları ve onay belgesi çekmek için kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Montaj fotoğraflarını galeriden seçmek için erişim gereklidir.",
        "NSPhotoLibraryAddUsageDescription": "Montaj fotoğraflarını kaydetmek için erişim gereklidir."
      }
    },
    "android": {
      "package": "com.ekolglassmontajtakip.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {}
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Montaj fotoğraflarını galeriden seçmek için erişim gereklidir.",
          "cameraPermission": "Montaj fotoğrafları ve onay belgesi çekmek için kamera erişimi gereklidir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
