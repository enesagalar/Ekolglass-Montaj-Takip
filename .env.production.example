# ====================================================
#  API Sunucu — Üretim Ortam Değişkenleri
#  Bu dosyayı kopyala: cp .env.production.example .env.production
#  .env.production'ı ASLA git'e gönderme!
# ====================================================

PORT=8080
NODE_ENV=production

# Supabase (mevcut proje bilgilerini kullan)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Oturum güvenliği (en az 32 karakter rastgele string)
SESSION_SECRET=buraya_cok_uzun_ve_rastgele_bir_sifre_yaz

# Cloudflare R2
R2_ACCOUNT_ID=cloudflare_account_id
R2_ACCESS_KEY_ID=r2_access_key
R2_SECRET_ACCESS_KEY=r2_secret_key
R2_BUCKET_NAME=ekolglass-photos
R2_PUBLIC_URL=https://photos.YOUR_DOMAIN.com
