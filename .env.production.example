# ====================================================
#  API Sunucu — Üretim Ortam Değişkenleri
#  Bu dosyayı kopyala: cp .env.production.example .env.production
#  .env.production'ı ASLA git'e gönderme!
# ====================================================

PORT=3000
NODE_ENV=production

# PostgreSQL bağlantısı (docker-compose ile çalışıyorsa postgres container adı)
DATABASE_URL=postgresql://ekolglass:GUCLU_SIFRE_YAZIN@postgres:5432/ekolglass

# JWT imzalama anahtarı — en az 64 karakter rastgele string
# Üretmek için: openssl rand -hex 64
JWT_SECRET=buraya_en_az_64_karakter_rastgele_string_yaz

# Cloudflare R2 fotoğraf depolama
R2_ACCOUNT_ID=cloudflare_account_id
R2_ACCESS_KEY_ID=r2_access_key
R2_SECRET_ACCESS_KEY=r2_secret_key
R2_BUCKET_NAME=ekolglass-photos
R2_PUBLIC_URL=https://photos.DOMAININIZ.com

# API'nin dışarıya açık adresi (fotoğraf proxy için)
# Örn: http://46.225.233.65:3000 veya https://api.siteniz.com
API_BASE_URL=http://SUNUCU_IP:3000
